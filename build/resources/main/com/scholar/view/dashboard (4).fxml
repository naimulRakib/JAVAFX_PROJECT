<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.text.Font?>

<!--
  dashboard.fxml — Dark-polished rewrite
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  BUG FIXES:
  1. WHITE GAPS IN NOTICES SCROLLPANE:
     JavaFX ScrollPane has a .viewport child that ignores
     "-fx-background-color:transparent" and falls back to
     white. Fix: set BOTH -fx-background AND -fx-background-color
     to the card's dark colour (#0f1020). Same fix applied to
     all other ScrollPanes in the file.

  2. CALENDAR WHITE BOXES:
     CalendarController.createDayBox() hardcodes white/light
     CSS. Fixed in CalendarController.java (see that file).

  3. TAB BAR:
     Replaced boring plain text="..." style="-fx-font-weight:bold"
     tabs with <graphic> Label tabs. Each Label is styled inline
     so the tab button looks like a pill nav. The TabPane CSS
     properties set the header-area background to a polished
     dark gradient. ALL fx:id / onAction / onSelectionChanged /
     closable attributes and all inner content are 100% UNCHANGED.

  NO INNER LOGIC TOUCHED.
-->
<BorderPane
    prefHeight="860.0" prefWidth="1300.0"
    style="-fx-background-color:#0d0f1a;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.scholar.controller.DashboardController">

    <!-- ══ TOP BAR ════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:linear-gradient(to right,#0a0c1e,#12142e,#0a0e20);
                     -fx-padding:12 24;
                     -fx-border-color:rgba(99,102,241,0.22);
                     -fx-border-width:0 0 1 0;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.65),18,0,0,5);">

            <VBox alignment="CENTER_LEFT" spacing="1">
                <Label text="ScholarGrid"
                       style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;
                              -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.45),10,0,0,0);"/>
                <Label text="Your Intelligent Study Hub"
                       style="-fx-font-size:10;-fx-text-fill:#6366f1;-fx-font-weight:bold;"/>
            </VBox>

            <Separator orientation="VERTICAL" style="-fx-opacity:0.15;"/>

            <HBox alignment="CENTER" spacing="8"
                  style="-fx-background-color:rgba(99,102,241,0.1);
                         -fx-border-color:rgba(99,102,241,0.32);
                         -fx-border-radius:20;-fx-background-radius:20;
                         -fx-padding:5 14;">
                <Label text="🏛" style="-fx-font-size:13;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="WORKSPACE"
                           style="-fx-font-size:9;-fx-font-weight:bold;-fx-text-fill:#6366f1;"/>
                    <Label fx:id="channelNameLabel" text="Loading..."
                           style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#fbbf24;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="8" alignment="CENTER">
                <Button fx:id="aiTutorBtn" text="🤖 AI Tutor"
                        style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                               -fx-text-fill:white;-fx-font-weight:bold;
                               -fx-background-radius:20;-fx-padding:7 18;
                               -fx-cursor:hand;-fx-font-size:12;
                               -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.55),8,0,0,3);"/>
                <Button text="Logout 🚪"
                        style="-fx-background-color:transparent;-fx-text-fill:#64748b;
                               -fx-border-color:rgba(100,116,139,0.32);
                               -fx-border-radius:20;-fx-background-radius:20;
                               -fx-padding:7 18;-fx-cursor:hand;-fx-font-size:12;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ══ TAB PANE ═══════════════════════════════════════════
         Tab styling strategy:
           • Remove default text by leaving text="" and using
             <graphic> Label instead — full CSS control.
           • Tab header background set via -fx-tab-header-*
             properties directly on the TabPane style string.
           • Each tab graphic Label has padding 0 4 so tabs are
             compact. The platform draws the active-tab underline
             indicator on top automatically.
    ══════════════════════════════════════════════════════════ -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color:#0d0f1a;
                        -fx-tab-min-height:44;
                        -fx-tab-max-height:44;
                        -fx-tab-min-width:0;
                        -fx-focus-color:transparent;
                        -fx-faint-focus-color:transparent;
                        -fx-tab-header-area-background-color:linear-gradient(to bottom,#0b0d1c,#0f1120);
                        -fx-tab-header-background:linear-gradient(to bottom,#0b0d1c,#0f1120);
                        -fx-border-width:0;">

            <!-- ── TAB 1 · 🏠 Dashboard ────────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🏠  Dashboard"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>

                <SplitPane dividerPositions="0.28"
                           style="-fx-background-color:transparent;-fx-padding:12;">

                    <!-- LEFT: AI Scheduler -->
                    <VBox spacing="14" SplitPane.resizableWithParent="false"
                          style="-fx-background-color:linear-gradient(to bottom,#12142a,#1a1c38);
                                 -fx-background-radius:14;-fx-padding:22;
                                 -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;
                                 -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.2),16,0,0,5);">
                        <VBox spacing="3">
                            <Label text="✨ AI Scheduler"
                                   style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#818cf8;"/>
                            <Label text="Describe your goals — AI does the rest"
                                   style="-fx-font-size:11;-fx-text-fill:#475569;"/>
                        </VBox>
                        <HBox spacing="6">
                            <Button text="📚 Exam prep"
                                    style="-fx-background-color:rgba(99,102,241,0.15);-fx-text-fill:#818cf8;
                                           -fx-border-color:rgba(99,102,241,0.3);-fx-border-radius:12;
                                           -fx-background-radius:12;-fx-padding:4 10;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="⏰ Daily plan"
                                    style="-fx-background-color:rgba(6,182,212,0.15);-fx-text-fill:#22d3ee;
                                           -fx-border-color:rgba(6,182,212,0.3);-fx-border-radius:12;
                                           -fx-background-radius:12;-fx-padding:4 10;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="🎯 Sprint"
                                    style="-fx-background-color:rgba(16,185,129,0.15);-fx-text-fill:#34d399;
                                           -fx-border-color:rgba(16,185,129,0.3);-fx-border-radius:12;
                                           -fx-background-radius:12;-fx-padding:4 10;-fx-cursor:hand;-fx-font-size:11;"/>
                        </HBox>
                        <TextArea fx:id="inputArea"
                                  promptText="Example: Calculus midterm Friday — make a 3-day plan..."
                                  wrapText="true" VBox.vgrow="ALWAYS"
                                  style="-fx-control-inner-background:#080a14;-fx-text-fill:#e2e8f0;
                                         -fx-prompt-text-fill:#334155;-fx-background-radius:10;
                                         -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:10;
                                         -fx-font-size:13;-fx-padding:12;"/>
                        <Button fx:id="generateBtn" maxWidth="Infinity"
                                onAction="#onGenerateClick" text="⚡ Generate My Schedule"
                                style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                                       -fx-text-fill:white;-fx-cursor:hand;-fx-background-radius:10;
                                       -fx-font-weight:bold;-fx-font-size:13;-fx-padding:12 0;
                                       -fx-effect:dropshadow(gaussian,rgba(99,102,241,0.6),12,0,0,4);"/>
                        <Button maxWidth="Infinity" onAction="#showManualTaskEntryDialog"
                                text="➕ Add Task Manually"
                                style="-fx-background-color:rgba(255,255,255,0.04);-fx-text-fill:#64748b;
                                       -fx-border-color:rgba(255,255,255,0.08);-fx-border-radius:10;
                                       -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:12;
                                       -fx-padding:9 0;"/>
                    </VBox>

                    <!-- RIGHT: Routine + Notices + Timeline
                         ScrollPane FIX: -fx-background sets the inner
                         Viewport fill; -fx-background-color sets the
                         ScrollPane node itself.  Both must be #0d0f1a. -->
                    <ScrollPane fitToWidth="true"
                                style="-fx-background:#0d0f1a;
                                       -fx-background-color:#0d0f1a;
                                       -fx-border-color:transparent;">
                        <VBox spacing="16"
                              style="-fx-padding:4 4 20 4;-fx-background-color:#0d0f1a;">

                            <!-- Routine card + Notices card side-by-side -->
                            <HBox spacing="14">

                                <!-- Class Routine -->
                                <VBox HBox.hgrow="ALWAYS"
                                      style="-fx-background-color:#0f1220;-fx-background-radius:14;
                                             -fx-padding:18;
                                             -fx-border-color:rgba(99,102,241,0.18);-fx-border-radius:14;
                                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.35),14,0,0,4);">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="📅" style="-fx-font-size:18;"/>
                                        <Label text="Class Routine"
                                               style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="editRoutineBtn" text="✏ Edit"
                                                style="-fx-background-color:rgba(251,191,36,0.14);
                                                       -fx-text-fill:#fbbf24;
                                                       -fx-border-color:rgba(251,191,36,0.28);
                                                       -fx-border-radius:8;-fx-background-radius:8;
                                                       -fx-cursor:hand;-fx-font-weight:bold;-fx-padding:5 12;"/>
                                    </HBox>
                                    <Separator style="-fx-opacity:0.1;-fx-padding:8 0 10 0;"/>
                                    <GridPane fx:id="routineGrid" hgap="18" vgap="8"
                                              style="-fx-font-size:13;-fx-text-fill:#94a3b8;"/>
                                </VBox>

                                <!-- ╔═══════════════════════════════════╗
                                     ║  NOTICES — WHITE-GAP ROOT FIX     ║
                                     ║                                    ║
                                     ║  The card VBox itself is #0f1020.  ║
                                     ║  The inner ScrollPane sets BOTH    ║
                                     ║    -fx-background:#0f1020          ║
                                     ║    -fx-background-color:#0f1020    ║
                                     ║  so JavaFX's .viewport node has    ║
                                     ║  no reason to fall back to white.  ║
                                     ║  The announcementList VBox also    ║
                                     ║  gets the same colour so there is  ║
                                     ║  zero gap between cards.           ║
                                     ╚═══════════════════════════════════╝ -->
                                <VBox prefWidth="290" minWidth="240"
                                      style="-fx-background-color:#0f1020;
                                             -fx-background-radius:14;
                                             -fx-border-color:rgba(236,72,153,0.25);
                                             -fx-border-width:0 0 0 3;
                                             -fx-border-radius:14;
                                             -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.12),16,0,0,4);">

                                    <!-- Padded inner column -->
                                    <VBox spacing="0" VBox.vgrow="ALWAYS"
                                          style="-fx-padding:16 14 14 14;
                                                 -fx-background-color:#0f1020;
                                                 -fx-background-radius:0 14 14 0;">

                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <Label text="📢" style="-fx-font-size:16;"/>
                                            <Label text="Notices"
                                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#f472b6;"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="postAnnouncementBtn" text="＋"
                                                    style="-fx-background-color:#be185d;-fx-text-fill:white;
                                                           -fx-background-radius:50;-fx-font-weight:bold;
                                                           -fx-cursor:hand;-fx-min-width:28;-fx-min-height:28;
                                                           -fx-max-width:28;-fx-max-height:28;"/>
                                        </HBox>

                                        <Separator style="-fx-opacity:0.1;-fx-padding:8 0 10 0;"/>

                                        <!-- VIEWPORT FIX: both properties must be set -->
                                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                                    style="-fx-background:#0f1020;
                                                           -fx-background-color:#0f1020;
                                                           -fx-border-color:transparent;
                                                           -fx-padding:0;">
                                            <VBox fx:id="announcementList" spacing="8"
                                                  style="-fx-background-color:#0f1020;
                                                         -fx-padding:4 0 10 0;"/>
                                        </ScrollPane>
                                    </VBox>
                                </VBox>

                            </HBox>

                            <!-- Timeline filter bar -->
                            <HBox alignment="CENTER_LEFT" spacing="12"
                                  style="-fx-background-color:#0f1220;-fx-background-radius:12;
                                         -fx-padding:12 18;
                                         -fx-border-color:rgba(99,102,241,0.15);-fx-border-radius:12;">
                                <Label text="🗓 My Timeline"
                                       style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="6">
                                    <Button fx:id="btnDailyTasks" text="📋 Today"
                                            style="-fx-background-color:rgba(99,102,241,0.2);-fx-text-fill:#818cf8;
                                                   -fx-border-color:rgba(99,102,241,0.35);-fx-border-radius:20;
                                                   -fx-background-radius:20;-fx-cursor:hand;-fx-font-weight:bold;
                                                   -fx-padding:5 14;-fx-font-size:12;"/>
                                    <Button fx:id="btnBacklog" text="🔴 Backlog"
                                            style="-fx-background-color:rgba(239,68,68,0.1);-fx-text-fill:#f87171;
                                                   -fx-border-color:rgba(239,68,68,0.25);-fx-border-radius:20;
                                                   -fx-background-radius:20;-fx-cursor:hand;-fx-font-weight:bold;
                                                   -fx-padding:5 14;-fx-font-size:12;"/>
                                    <Button fx:id="btnCompleted" text="✅ Done"
                                            style="-fx-background-color:rgba(16,185,129,0.1);-fx-text-fill:#34d399;
                                                   -fx-border-color:rgba(16,185,129,0.25);-fx-border-radius:20;
                                                   -fx-background-radius:20;-fx-cursor:hand;-fx-font-weight:bold;
                                                   -fx-padding:5 14;-fx-font-size:12;"/>
                                </HBox>
                            </HBox>

                            <!-- Timeline container (populated by TaskController) -->
                            <VBox fx:id="timelineContainer" spacing="8"
                                  style="-fx-background-color:#0f1220;-fx-background-radius:14;
                                         -fx-padding:18;
                                         -fx-border-color:rgba(99,102,241,0.15);-fx-border-radius:14;">
                                <Label text="📌 Your tasks for today will appear here"
                                       style="-fx-text-fill:#334155;-fx-font-size:13;"/>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </SplitPane>
            </Tab>

            <!-- ── TAB 2 · 📅 Calendar ─────────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="📅  Calendar"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <VBox spacing="14" style="-fx-padding:24;-fx-background-color:#0d0f1a;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="📅" style="-fx-font-size:26;"/>
                        <Label fx:id="monthLabel" text="February 2026"
                               style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                    </HBox>
                    <Separator style="-fx-opacity:0.15;"/>
                    <GridPane fx:id="calendarGrid" hgap="10" vgap="10" VBox.vgrow="ALWAYS"
                              style="-fx-background-color:transparent;"/>
                </VBox>
            </Tab>

            <!-- ── TAB 3 · 📚 Resources ────────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="📚  Resources"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <SplitPane dividerPositions="0.35"
                           style="-fx-background-color:#0d0f1a;-fx-padding:12;">
                    <VBox spacing="14"
                          style="-fx-background-color:linear-gradient(to bottom,#12142a,#1a1c38);
                                 -fx-background-radius:14;-fx-padding:22;
                                 -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
                        <Label text="✨ AI Study Guide"
                               style="-fx-font-size:17;-fx-font-weight:bold;-fx-text-fill:#818cf8;"/>
                        <Label text="Paste notes → get a structured guide"
                               style="-fx-font-size:11;-fx-text-fill:#475569;"/>
                        <TextField fx:id="resTitle" promptText="Topic (e.g. Graph Theory)"
                                   style="-fx-control-inner-background:#080a14;-fx-text-fill:#e2e8f0;
                                          -fx-prompt-text-fill:#334155;-fx-background-radius:9;
                                          -fx-border-color:rgba(99,102,241,0.3);-fx-border-radius:9;
                                          -fx-padding:10;"/>
                        <TextArea fx:id="resInput" promptText="Paste your raw notes here..."
                                  wrapText="true" VBox.vgrow="ALWAYS"
                                  style="-fx-control-inner-background:#080a14;-fx-text-fill:#e2e8f0;
                                         -fx-prompt-text-fill:#334155;-fx-background-radius:9;
                                         -fx-border-color:rgba(99,102,241,0.3);-fx-border-radius:9;
                                         -fx-padding:11;"/>
                        <Button maxWidth="Infinity" onAction="#onGenerateResource"
                                text="⚡ Generate &amp; Save"
                                style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                                       -fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:10;
                                       -fx-cursor:hand;-fx-font-size:13;-fx-padding:12 0;"/>
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color:#0f1220;-fx-background-radius:14;-fx-padding:20;
                                 -fx-border-color:rgba(99,102,241,0.18);-fx-border-radius:14;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📖" style="-fx-font-size:18;"/>
                            <Label text="Personal Library"
                                   style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button onAction="#loadResources" text="🔄 Refresh"
                                    style="-fx-background-color:rgba(99,102,241,0.12);
                                           -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:8;
                                           -fx-background-radius:8;-fx-cursor:hand;-fx-padding:6 12;
                                           -fx-font-size:12;-fx-text-fill:#818cf8;"/>
                        </HBox>
                        <Separator style="-fx-opacity:0.12;"/>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    style="-fx-background:#0f1220;
                                           -fx-background-color:#0f1220;
                                           -fx-border-color:transparent;">
                            <VBox fx:id="resourceList" spacing="10"
                                  style="-fx-background-color:#0f1220;"/>
                        </ScrollPane>
                    </VBox>
                </SplitPane>
            </Tab>

            <!-- ── TAB 4 · 🎓 Community ────────────────────── -->
            <!--
                RESOURCE PANEL WIRING
                ══════════════════════════════════════════════════════════
                ResourceTableController.init() receives the TableView +
                all 7 columns, then calls injectCardView() which REPLACES
                the TableView at runtime with a dark card ScrollPane.
                The TableView must still exist here so the parent VBox
                and VBox.vgrow="ALWAYS" constraint are present for the
                injection to copy them.

                ResourceTableController.initExtras() wires:
                  fx:id="typeFilterCombo"    ComboBox  – type filter
                  fx:id="diffFilterCombo"    ComboBox  – difficulty filter
                  fx:id="sortCombo"          ComboBox  – sort order
                  fx:id="statusBarLabel"     Label     – status bar text
                  fx:id="loadingLabel"       Label     – "Loading…" text
                  fx:id="loadingIndicator"   ProgressIndicator
                  fx:id="resourceCountLabel" Label     – "N resource(s)"

                The inline search TextField calls DashboardController
                #onResourceSearch which delegates to filterByText().
                ══════════════════════════════════════════════════════════
            -->
            <Tab closable="false">
                <graphic>
                    <Label text="🎓  Community"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>

                <SplitPane dividerPositions="0.24"
                           style="-fx-background-color:#0d0f1a;-fx-padding:12;">

                    <!-- ═══ LEFT PANEL — Course/Topic Tree ═══ -->
                    <VBox spacing="10" SplitPane.resizableWithParent="false"
                          style="-fx-background-color:#0f1220;-fx-padding:16;
                                 -fx-background-radius:14;
                                 -fx-border-color:rgba(99,102,241,0.18);-fx-border-radius:14;">

                        <!-- Explorer header -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📂  Explorer"
                                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#818cf8;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🔄" onAction="#onRefreshCommunity"
                                    style="-fx-background-color:rgba(99,102,241,0.12);
                                           -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:8;
                                           -fx-background-radius:8;-fx-text-fill:#818cf8;
                                           -fx-cursor:hand;-fx-padding:5 10;-fx-font-size:13;"/>
                        </HBox>

                        <!-- Course search -->
                        <TextField fx:id="communitySearchField"
                                   promptText="🔍  Search course..."
                                   style="-fx-background-radius:20;-fx-padding:8 14;
                                          -fx-control-inner-background:#0d0f1a;
                                          -fx-text-fill:#e2e8f0;-fx-prompt-text-fill:#334155;
                                          -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:20;"/>

                        <!-- Tree -->
                        <TreeView fx:id="communityTree" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color:transparent;
                                         -fx-border-color:transparent;-fx-font-size:13;"/>

                        <!-- Add Course button -->
                        <Button text="➕  Add Course / Folder"
                                onAction="#onAddNewFolder"
                                maxWidth="Infinity"
                                style="-fx-background-color:linear-gradient(to right,#4f46e5,#6366f1);
                                       -fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-background-radius:10;-fx-padding:10;-fx-cursor:hand;"/>
                    </VBox>

                    <!-- ═══ RIGHT PANEL — Resource Cards ═══ -->
                    <VBox spacing="0"
                          style="-fx-background-color:#0a0f1c;-fx-background-radius:14;
                                 -fx-border-color:rgba(99,102,241,0.18);-fx-border-radius:14;">

                        <!-- ── Top bar: breadcrumb + search + upload ── -->
                        <VBox style="-fx-background-color:#0f1220;
                                     -fx-background-radius:14 14 0 0;
                                     -fx-padding:14 18 12 18;
                                     -fx-border-color:transparent transparent rgba(99,102,241,0.12) transparent;
                                     -fx-border-width:0 0 1 0;">

                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label fx:id="currentFolderLabel" text="Select a topic..."
                                       style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#94a3b8;"
                                       HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Button text="📤  Upload Resource"
                                        onAction="#onUploadResourceClick"
                                        style="-fx-background-color:linear-gradient(to right,#10b981,#06b6d4);
                                               -fx-text-fill:white;-fx-font-weight:bold;
                                               -fx-background-radius:20;-fx-padding:9 18;
                                               -fx-cursor:hand;-fx-font-size:12;"/>
                            </HBox>

                            <!-- ── Filter bar ── -->
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-padding:10 0 0 0;">

                                <!-- Type filter -->
                                <VBox spacing="3">
                                    <Label text="TYPE"
                                           style="-fx-text-fill:#334155;-fx-font-size:10;-fx-font-weight:bold;"/>
                                    <ComboBox fx:id="typeFilterCombo" prefWidth="100"
                                              style="-fx-background-color:#111827;-fx-font-size:12;"/>
                                </VBox>

                                <!-- Difficulty filter -->
                                <VBox spacing="3">
                                    <Label text="DIFFICULTY"
                                           style="-fx-text-fill:#334155;-fx-font-size:10;-fx-font-weight:bold;"/>
                                    <ComboBox fx:id="diffFilterCombo" prefWidth="110"
                                              style="-fx-background-color:#111827;-fx-font-size:12;"/>
                                </VBox>

                                <!-- Sort -->
                                <VBox spacing="3">
                                    <Label text="SORT BY"
                                           style="-fx-text-fill:#334155;-fx-font-size:10;-fx-font-weight:bold;"/>
                                    <ComboBox fx:id="sortCombo" prefWidth="140"
                                              style="-fx-background-color:#111827;-fx-font-size:12;"/>
                                </VBox>

                                <Region HBox.hgrow="ALWAYS"/>

                                <!-- Inline resource search -->
                                <VBox spacing="3">
                                    <Label text="SEARCH"
                                           style="-fx-text-fill:#334155;-fx-font-size:10;-fx-font-weight:bold;"/>
                                    <TextField fx:id="resourceSearchField"
                                               promptText="🔍  Search resources..."
                                               prefWidth="200"
                                               onKeyReleased="#onResourceSearch"
                                               style="-fx-background-radius:20;-fx-padding:7 14;
                                                      -fx-control-inner-background:#0d0f1a;
                                                      -fx-text-fill:#e2e8f0;-fx-prompt-text-fill:#334155;
                                                      -fx-border-color:rgba(99,102,241,0.25);
                                                      -fx-border-radius:20;-fx-font-size:12;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- ── Loading indicator (hidden by default) ── -->
                        <HBox fx:id="loadingBar" alignment="CENTER_LEFT" spacing="10"
                              visible="false" managed="false"
                              style="-fx-background-color:#0d1220;
                                     -fx-padding:8 18;
                                     -fx-border-color:transparent transparent rgba(99,102,241,0.1) transparent;
                                     -fx-border-width:0 0 1 0;">
                            <ProgressIndicator fx:id="loadingIndicator"
                                               prefWidth="18" prefHeight="18"
                                               style="-fx-progress-color:#6366f1;"/>
                            <Label fx:id="loadingLabel" text="Loading resources…"
                                   style="-fx-text-fill:#334155;-fx-font-size:12;"/>
                        </HBox>

                        <!-- ── Card area — TableView lives here, gets replaced at runtime ── -->
                        <!--
                            WHY THE TABLEVIEW STAYS:
                            ResourceTableController.injectCardView() calls
                              parent.getChildren().set(idx, cardScroll)
                            so the TableView's index in this VBox is what
                            positions the card scroll pane correctly.
                            VBox.vgrow="ALWAYS" is copied to cardScroll.
                        -->
                        <TableView fx:id="resourceTable" VBox.vgrow="ALWAYS"
                                   style="-fx-font-size:13;-fx-background-color:#0a0f1c;
                                          -fx-background-radius:0 0 14 14;
                                          -fx-border-color:transparent;">
                            <columns>
                                <TableColumn fx:id="colResName"     text="Resource Name" prefWidth="210"/>
                                <TableColumn fx:id="colResType"     text="Type"          prefWidth="75"/>
                                <TableColumn fx:id="colResDiff"     text="Level"         prefWidth="80"/>
                                <TableColumn fx:id="colResUploader" text="Uploader"      prefWidth="110"/>
                                <TableColumn fx:id="colResTags"     text="Tags"          prefWidth="130"/>
                                <TableColumn fx:id="colResVotes"    text="Votes"         prefWidth="100"/>
                                <TableColumn fx:id="colResAction"   text="Actions"       prefWidth="240"/>
                            </columns>
                        </TableView>

                        <!-- ── Status bar ── -->
                        <HBox alignment="CENTER_LEFT" spacing="14"
                              style="-fx-background-color:#080d18;
                                     -fx-background-radius:0 0 14 14;
                                     -fx-padding:7 18;
                                     -fx-border-color:rgba(99,102,241,0.1) transparent transparent transparent;
                                     -fx-border-width:1 0 0 0;">
                            <Label fx:id="resourceCountLabel" text="0 resource(s)"
                                   style="-fx-text-fill:#1e3a5f;-fx-font-size:11;-fx-font-weight:bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="statusBarLabel" text="Ready"
                                   style="-fx-text-fill:#1e3a5f;-fx-font-size:11;"/>
                        </HBox>

                    </VBox>
                </SplitPane>
            </Tab>

            <!-- ── TAB 5 · 🤝 Collaborate ─────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🤝  Collaborate"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="collaboration.fxml"/>
                </content>
            </Tab>

            <!-- ── TAB 6 · 🏆 ECA ─────────────────────────── -->
            <Tab onSelectionChanged="#handleECATrackerSelect" closable="false">
                <graphic>
                    <Label text="🏆  ECA"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <VBox alignment="TOP_CENTER" spacing="18"
                      style="-fx-padding:24;-fx-background-color:#0d0f1a;">
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="🔄 Refresh Stats" onAction="#forceRefreshECA"
                                style="-fx-background-color:rgba(99,102,241,0.12);
                                       -fx-border-color:rgba(99,102,241,0.25);
                                       -fx-border-radius:8;-fx-background-radius:8;
                                       -fx-cursor:hand;-fx-padding:8 16;-fx-font-size:12;
                                       -fx-text-fill:#818cf8;"/>
                    </HBox>
                    <VBox fx:id="ecaContainer" alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>

            <!-- ── TAB 7 · ⚙️ Settings ────────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="⚙️  Settings"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <fx:include source="profile_settings.fxml"/>
            </Tab>

            <!-- ── TAB 8 · 🛡️ Admin ───────────────────────── -->
            <Tab fx:id="adminTab" closable="false">
                <graphic>
                    <Label text="🛡️  Admin"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <ScrollPane fitToWidth="true"
                                style="-fx-background:#0d0f1a;
                                       -fx-background-color:#0d0f1a;">
                        <VBox spacing="18"
                              style="-fx-padding:24 32;-fx-background-color:#0d0f1a;">

                            <VBox spacing="3">
                                <Label text="Admin Control Panel"
                                       style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                                <Label text="Manage platform settings, member requests, and social features."
                                       style="-fx-font-size:12;-fx-text-fill:#475569;"/>
                                <Separator style="-fx-opacity:0.15;"/>
                            </VBox>

                            <TabPane tabClosingPolicy="UNAVAILABLE"
                                     style="-fx-tab-min-height:36;-fx-background-color:transparent;">

                                <Tab text="⚙️ General" closable="false">
                                    <VBox spacing="18" style="-fx-padding:18 0 0 0;">
                                        <VBox fx:id="adminControlsBox" spacing="10">
                                            <Label text="⚙️ Chat Controls"
                                                   style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                                        </VBox>
                                        <Separator style="-fx-opacity:0.12;"/>
                                        <VBox spacing="10">
                                            <HBox alignment="CENTER_LEFT" spacing="12">
                                                <Label text="👥 Pending Member Requests"
                                                       style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"
                                                       HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                                <Button text="🔄 Refresh" onAction="#loadPendingRequests"
                                                        style="-fx-background-color:#2563eb;-fx-text-fill:white;
                                                               -fx-font-weight:bold;-fx-background-radius:8;
                                                               -fx-padding:7 16;-fx-cursor:hand;"/>
                                            </HBox>
                                            <VBox fx:id="pendingListContainer" spacing="8">
                                                <Label text="Click Refresh to load pending requests."
                                                       style="-fx-text-fill:#475569;-fx-font-size:12;"/>
                                            </VBox>
                                        </VBox>
                                        <Separator style="-fx-opacity:0.12;"/>
                                        <VBox spacing="10">
                                            <Label text="📢 Broadcast Tools"
                                                   style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                                            <HBox spacing="10">
                                                <Button text="📅 Broadcast Varsity Routine"
                                                        onAction="#onBroadcastRoutine"
                                                        style="-fx-background-color:#7c3aed;-fx-text-fill:white;
                                                               -fx-font-weight:bold;-fx-background-radius:8;
                                                               -fx-padding:9 18;-fx-cursor:hand;-fx-font-size:12;"/>
                                                <Button text="📢 Broadcast Official Notice"
                                                        onAction="#onBroadcastNotice"
                                                        style="-fx-background-color:#0891b2;-fx-text-fill:white;
                                                               -fx-font-weight:bold;-fx-background-radius:8;
                                                               -fx-padding:9 18;-fx-cursor:hand;-fx-font-size:12;"/>
                                            </HBox>
                                        </VBox>
                                    </VBox>
                                </Tab>

                                <Tab text="🔗 Channel Merge" closable="false">
                                    <content>
                                        <fx:include source="admin_merge.fxml"/>
                                    </content>
                                </Tab>

                            </TabPane>
                        </VBox>
                    </ScrollPane>
                </content>
            </Tab>

            <!-- ── TAB 9 · 🤖 AI Resources ────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🤖  AI Resources"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="latex_studio.fxml"/>
                </content>
            </Tab>

            <!-- ── TAB 10 · ⚡ Question Bank ──────────────── -->
            <Tab fx:id="questionBankTab" closable="false">
                <graphic>
                    <Label text="⚡  Question Bank"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <StackPane style="-fx-background-color:#0d0f1a;"/>
                </content>
            </Tab>

            <!-- ── TAB 11 · 🌎 Social Zone ────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🌎  Social Zone"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="social_zone.fxml"/>
                </content>
            </Tab>

            <!-- ── TAB 12 · 🎓 Mentorship ─────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🎓  Mentorship"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="consultancy_panel.fxml"/>
                </content>
            </Tab>

            <!-- ── TAB 13 · 🤖 AI Tutor ───────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🤖  AI Tutor"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <VBox spacing="12" style="-fx-padding:16;-fx-background-color:#0d0f1a;">
                        <WebView fx:id="aiWebView" VBox.vgrow="ALWAYS"
                                 style="-fx-border-radius:12;"/>
                        <HBox spacing="10" alignment="CENTER"
                              style="-fx-background-color:#0f1220;-fx-background-radius:14;-fx-padding:12 16;
                                     -fx-border-color:rgba(99,102,241,0.18);-fx-border-radius:14;">
                            <TextField fx:id="aiTopicInput" promptText="Topic (e.g. Recursion)"
                                       prefWidth="155"
                                       style="-fx-padding:10;-fx-background-radius:10;
                                              -fx-control-inner-background:#080a14;-fx-text-fill:#e2e8f0;
                                              -fx-prompt-text-fill:#334155;
                                              -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:10;"/>
                            <TextField fx:id="aiQuestionInput" promptText="Ask your question here..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-padding:10;-fx-background-radius:10;
                                              -fx-control-inner-background:#080a14;-fx-text-fill:#e2e8f0;
                                              -fx-prompt-text-fill:#334155;
                                              -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:10;"/>
                            <Button fx:id="aiAskBtn" text="Ask AI ✨"
                                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                                           -fx-text-fill:white;-fx-font-weight:bold;
                                           -fx-background-radius:12;-fx-padding:10 22;
                                           -fx-cursor:hand;-fx-font-size:13;"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ── TAB 14 · 🚪 Logout (onSelectionChanged) ── -->
            <Tab onSelectionChanged="#handleLogoutTab" closable="false">
                <graphic>
                    <Label text="🚪  Logout"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#f87171;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <VBox alignment="CENTER" spacing="18"
                          style="-fx-background-color:#0d0f1a;">
                        <Label text="Signing you out of ScholarGrid..."
                               style="-fx-font-size:15;-fx-text-fill:#64748b;"/>
                        <ProgressIndicator maxWidth="50" maxHeight="50"
                                           style="-fx-progress-color:#6366f1;"/>
                    </VBox>
                </content>
            </Tab>

            <!-- ── TAB 15 · 📖 Study Room ─────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="📖  Study Room"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="study_room.fxml"/>
                </content>
            </Tab>

            <!-- ── TAB 16 · 🎮 Game Zone ──────────────────── -->
            <Tab closable="false">
                <graphic>
                    <Label text="🎮  Game Zone"
                           style="-fx-font-size:12;-fx-font-weight:bold;
                                  -fx-text-fill:#94a3b8;-fx-cursor:hand;-fx-padding:0 4;"/>
                </graphic>
                <content>
                    <fx:include source="game_zone.fxml"/>
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
