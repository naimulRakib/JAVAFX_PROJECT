<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
  lobby.fxml — RESPONSIVE dark-theme rewrite
  Key fixes:
    • Root VBox fills window; inner cards have maxWidth="480" + center alignment
    • HBox/TextField children use HBox.hgrow="ALWAYS" + maxWidth="Infinity"
    • No hardcoded prefWidth on the root that would cut off on resize
-->
<VBox alignment="CENTER" spacing="28"
      style="-fx-background-color:#080a14;-fx-padding:48;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.scholar.controller.LobbyController">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="6">
        <Label text="Welcome to ScholarGrid! 🎓"
               style="-fx-font-size:30;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
        <Label text="Enter your multiverse: Join a class or create a new one."
               style="-fx-font-size:13;-fx-text-fill:#475569;"/>
    </VBox>

    <!-- JOIN card -->
    <VBox maxWidth="480" spacing="12"
          style="-fx-background-color:#141828;-fx-background-radius:14;
                 -fx-border-color:rgba(37,99,235,0.35);-fx-border-radius:14;
                 -fx-padding:24;
                 -fx-effect:dropshadow(gaussian,rgba(37,99,235,0.2),18,0,0,5);">
        <Label text="Student? Join a Classroom 🚀"
               style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#60a5fa;"/>
        <Label text="Ask your CR for the unique code."
               style="-fx-text-fill:#334155;-fx-font-size:12;"/>
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="joinCodeField" promptText="Enter Code (e.g. CSE24)"
                       HBox.hgrow="ALWAYS" maxWidth="Infinity"
                       style="-fx-font-size:14;-fx-padding:11;-fx-background-radius:10;
                              -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                              -fx-prompt-text-fill:#334155;
                              -fx-border-color:rgba(37,99,235,0.3);-fx-border-radius:10;"/>
            <Button onAction="#onJoinClick" text="Join Class"
                    style="-fx-background-color:#2563eb;-fx-text-fill:white;-fx-font-weight:bold;
                           -fx-cursor:hand;-fx-padding:11 20;-fx-background-radius:10;-fx-font-size:13;"/>
        </HBox>
    </VBox>

    <!-- OR divider -->
    <HBox alignment="CENTER" spacing="14" maxWidth="480">
        <Separator HBox.hgrow="ALWAYS" style="-fx-opacity:0.15;"/>
        <Label text="OR" style="-fx-text-fill:#334155;-fx-font-weight:bold;-fx-font-size:12;"/>
        <Separator HBox.hgrow="ALWAYS" style="-fx-opacity:0.15;"/>
    </HBox>

    <!-- CREATE card -->
    <VBox maxWidth="480" spacing="12"
          style="-fx-background-color:#141828;-fx-background-radius:14;
                 -fx-border-color:rgba(217,119,6,0.35);-fx-border-radius:14;
                 -fx-padding:24;
                 -fx-effect:dropshadow(gaussian,rgba(217,119,6,0.2),18,0,0,5);">
        <Label text="CR / Teacher? Create a New Channel 🛠️"
               style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#fbbf24;"/>
        <VBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Class Name:" style="-fx-text-fill:#475569;-fx-font-size:12;"/>
            <TextField fx:id="createNameField" promptText="e.g. BUET CSE-24"
                       maxWidth="Infinity"
                       style="-fx-font-size:13;-fx-padding:11;-fx-background-radius:10;
                              -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                              -fx-prompt-text-fill:#334155;
                              -fx-border-color:rgba(217,119,6,0.3);-fx-border-radius:10;"/>
            <Label text="Unique Join Code:" style="-fx-text-fill:#475569;-fx-font-size:12;"/>
            <TextField fx:id="createCodeField" promptText="e.g. CSE24-BUET"
                       maxWidth="Infinity"
                       style="-fx-font-size:13;-fx-padding:11;-fx-background-radius:10;
                              -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                              -fx-prompt-text-fill:#334155;
                              -fx-border-color:rgba(217,119,6,0.3);-fx-border-radius:10;"/>
        </VBox>
        <Button onAction="#onCreateClick" text="Create Channel &amp; Enter"
                maxWidth="Infinity"
                style="-fx-background-color:linear-gradient(to right,#d97706,#f59e0b);
                       -fx-text-fill:white;-fx-font-weight:bold;-fx-cursor:hand;
                       -fx-font-size:14;-fx-padding:12;-fx-background-radius:10;
                       -fx-effect:dropshadow(gaussian,rgba(217,119,6,0.4),10,0,0,3);"/>
    </VBox>

    <Label fx:id="statusLabel" text="Ready to connect..."
           style="-fx-text-fill:#334155;-fx-font-size:13;"/>
</VBox>
