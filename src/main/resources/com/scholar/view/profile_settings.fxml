<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<!--
  profile_settings.fxml — RESPONSIVE dark-theme rewrite
  Key fixes:
    • ScrollPane root: fitToWidth="true" — fills available width
    • GridPane column 1 uses hgrow="ALWAYS" — fields stretch to fill space
    • All cards use maxWidth="Infinity" — no fixed-width cutting
    • Removed all hardcoded prefWidth on cards
-->
<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color:#0d0f1a;-fx-border-color:transparent;"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.scholar.controller.settings.ProfileController">

    <stylesheets>
        <String fx:value="/com/scholar/view/css/profile-settings-dark.css"/>
    </stylesheets>

<VBox spacing="0" fx:id="profileRoot" style="-fx-background-color:#0d0f1a;">

    <!-- ══ HERO HEADER ══════════════════════════════════════ -->
    <VBox fx:id="heroHeader" alignment="CENTER" spacing="12"
          style="-fx-padding:32 40 26 40;
                 -fx-background-color:linear-gradient(to right,#1e1b4b,#312e81);
                 -fx-border-color:rgba(99,102,241,0.3);-fx-border-width:0 0 1 0;">

        <StackPane maxWidth="108" maxHeight="108" minWidth="108" minHeight="108">
            <Circle radius="54" fill="rgba(255,255,255,0.06)"
                    stroke="rgba(255,255,255,0.45)" strokeWidth="2.5"/>
            <ImageView fx:id="avatarView" fitWidth="100" fitHeight="100"
                       preserveRatio="false"/>
        </StackPane>

        <Label fx:id="userNameLabel" text="Scholar"
               style="-fx-font-size:19;-fx-font-weight:bold;-fx-text-fill:white;"/>
        <Label text="Student Profile"
               style="-fx-font-size:11;-fx-text-fill:#c7d2fe;"/>

        <HBox alignment="CENTER" spacing="10">
            <ProgressBar fx:id="completionBar" prefWidth="220" prefHeight="7"
                         progress="0.0"
                         style="-fx-accent:#a5f3fc;-fx-background-color:#ffffff1a;
                                -fx-background-radius:4;"/>
            <Label fx:id="completionLabel" text="0% complete"
                   style="-fx-text-fill:#c7d2fe;-fx-font-size:11;"/>
        </HBox>

        <Button text="📷 Change Photo" onAction="#onUploadAvatar"
                style="-fx-background-color:rgba(255,255,255,0.1);-fx-text-fill:white;
                       -fx-border-color:rgba(255,255,255,0.3);-fx-border-radius:20;
                       -fx-background-radius:20;-fx-padding:6 18;-fx-cursor:hand;-fx-font-size:12;"/>
    </VBox>

    <!-- ══ BODY ══════════════════════════════════════════════ -->
    <VBox spacing="18" style="-fx-padding:22 28 28 28;-fx-background-color:#0d0f1a;">

        <!-- Shared card style applied inline — using CSS class via stylesheet for radius/bg -->

        <!-- ── Basic Identity ──────────────────────────────── -->
        <VBox spacing="14"
              style="-fx-background-color:#141828;-fx-background-radius:14;-fx-padding:20;
                     -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
            <Label text="👤 Basic Identity"
                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
            <Separator style="-fx-opacity:0.12;"/>
            <GridPane hgap="14" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="95" maxWidth="115"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="100"/>
                </columnConstraints>
                 <Label text="User Name" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfUsername" promptText="Enter your unique nickname: "
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>



                <Label text="Full Name" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfFullName" promptText="Your full name"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Student ID" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfStudentId" promptText="2021-1-60-001"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="University" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfUniversity" promptText="University name"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Department" GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfDepartment" promptText="CSE, EEE…"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Batch / Sem" GridPane.rowIndex="4" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfBatchSemester" promptText="52A / 8th"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Email" GridPane.rowIndex="5" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfEmail" promptText="you@example.com"
                           GridPane.rowIndex="5" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Phone" GridPane.rowIndex="6" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <HBox spacing="8" GridPane.rowIndex="6" GridPane.columnIndex="1">
                    <TextField fx:id="tfPhone" promptText="+880 1XXXXXXXXX"
                               HBox.hgrow="ALWAYS"
                               style="-fx-padding:9;-fx-background-radius:9;
                                      -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                      -fx-prompt-text-fill:#334155;
                                      -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>
                    <ToggleButton fx:id="togglePhonePublic" text="Public"
                                  style="-fx-background-color:rgba(99,102,241,0.12);-fx-text-fill:#818cf8;
                                         -fx-border-color:rgba(99,102,241,0.3);-fx-border-radius:9;
                                         -fx-background-radius:9;-fx-padding:6 14;-fx-cursor:hand;"/>
                </HBox>
            </GridPane>
            <Button text="💾 Save Identity" onAction="#onSaveBasic"
                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                           -fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13;"/>
        </VBox>

        <!-- ── Academic Info ───────────────────────────────── -->
        <VBox spacing="14"
              style="-fx-background-color:#141828;-fx-background-radius:14;-fx-padding:20;
                     -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
            <Label text="🎓 Academic Info"
                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
            <Separator style="-fx-opacity:0.12;"/>
            <GridPane hgap="14" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="95" maxWidth="115"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="100"/>
                </columnConstraints>

                <Label text="CGPA" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <HBox spacing="12" alignment="CENTER_LEFT"
                      GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <TextField fx:id="tfCgpa" promptText="3.75" prefWidth="100"
                               style="-fx-padding:9;-fx-background-radius:9;
                                      -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                      -fx-prompt-text-fill:#334155;
                                      -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>
                    <CheckBox fx:id="cbCgpaVisible" text="Show publicly" selected="true"
                              style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                </HBox>

                <Label text="Credits" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfCredits" promptText="120" prefWidth="100"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Thesis / Project" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfThesis" promptText="Optional"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Interests" GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfInterests" promptText="AI, Web Dev, Research"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Courses" GridPane.rowIndex="4" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfCourses" promptText="CSE301, CSE315"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>
            </GridPane>
            <Button text="💾 Save Academic" onAction="#onSaveAcademic"
                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                           -fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13;"/>
        </VBox>

        <!-- ── Skills ──────────────────────────────────────── -->
        <VBox spacing="14"
              style="-fx-background-color:#141828;-fx-background-radius:14;-fx-padding:20;
                     -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
            <Label text="⭐ Skills &amp; Tech Stack"
                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
            <Separator style="-fx-opacity:0.12;"/>
            <GridPane hgap="14" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="95" maxWidth="115"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="100"/>
                </columnConstraints>

                <Label text="Languages" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfProgLangs" promptText="Java, Python, C, C++"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Frameworks" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfFrameworks" promptText="JavaFX, Spring Boot, Git"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Soft Skills" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfSoftSkills" promptText="Teamwork, Leadership"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>
            </GridPane>
            <Label text="Tip: separate each item with a comma"
                   style="-fx-text-fill:#334155;-fx-font-size:11;"/>
            <Button text="💾 Save Skills" onAction="#onSaveSkills"
                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                           -fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13;"/>
        </VBox>

        <!-- ── Social Links ────────────────────────────────── -->
        <VBox spacing="14"
              style="-fx-background-color:#141828;-fx-background-radius:14;-fx-padding:20;
                     -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
            <Label text="🔗 Social &amp; Career Links"
                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
            <Separator style="-fx-opacity:0.12;"/>
            <GridPane hgap="14" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="95" maxWidth="115"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="100"/>
                </columnConstraints>

                <Label text="GitHub" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfGithub" promptText="https://github.com/username"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="LinkedIn" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfLinkedin" promptText="https://linkedin.com/in/..."
                           GridPane.rowIndex="1" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Portfolio" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfPortfolio" promptText="https://yoursite.com"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="Codeforces" GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfCodeforces" promptText="handle"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>

                <Label text="LeetCode" GridPane.rowIndex="4" GridPane.columnIndex="0"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <TextField fx:id="tfLeetcode" promptText="handle"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                           maxWidth="Infinity"
                           style="-fx-padding:9;-fx-background-radius:9;
                                  -fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                  -fx-prompt-text-fill:#334155;
                                  -fx-border-color:rgba(99,102,241,0.25);-fx-border-radius:9;"/>
            </GridPane>
            <Button text="💾 Save Links" onAction="#onSaveLinks"
                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                           -fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13;"/>
        </VBox>

        <!-- ── Privacy & Settings ──────────────────────────── -->
        <VBox spacing="14"
              style="-fx-background-color:#141828;-fx-background-radius:14;-fx-padding:20;
                     -fx-border-color:rgba(99,102,241,0.2);-fx-border-radius:14;">
            <Label text="🔒 Privacy &amp; Settings"
                   style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
            <Separator style="-fx-opacity:0.12;"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Theme" minWidth="90"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <ToggleButton text="🌙 Dark" userData="DARK" selected="true"
                              style="-fx-background-color:rgba(99,102,241,0.2);-fx-text-fill:#818cf8;
                                     -fx-border-color:rgba(99,102,241,0.3);-fx-border-radius:9;
                                     -fx-background-radius:9;-fx-padding:6 14;-fx-cursor:hand;">
                    <toggleGroup><ToggleGroup fx:id="themeGroup"/></toggleGroup>
                </ToggleButton>
                <ToggleButton text="☀ Light" userData="LIGHT" toggleGroup="$themeGroup"
                              style="-fx-background-color:rgba(255,255,255,0.06);-fx-text-fill:#94a3b8;
                                     -fx-border-color:rgba(255,255,255,0.1);-fx-border-radius:9;
                                     -fx-background-radius:9;-fx-padding:6 14;-fx-cursor:hand;"/>
                <ToggleButton text="⚙ System" userData="SYSTEM" toggleGroup="$themeGroup"
                              style="-fx-background-color:rgba(255,255,255,0.06);-fx-text-fill:#94a3b8;
                                     -fx-border-color:rgba(255,255,255,0.1);-fx-border-radius:9;
                                     -fx-background-radius:9;-fx-padding:6 14;-fx-cursor:hand;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Accent" minWidth="90"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <ColorPicker fx:id="accentPicker"
                             style="-fx-background-color:#1e2235;-fx-border-color:rgba(99,102,241,0.25);
                                    -fx-border-radius:9;-fx-background-radius:9;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Font Size" minWidth="90"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <ComboBox fx:id="cbFontSize" value="Medium"
                          style="-fx-background-color:#1e2235;-fx-border-color:rgba(99,102,241,0.25);
                                 -fx-border-radius:9;-fx-background-radius:9;-fx-min-width:130;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Small"/>
                            <String fx:value="Medium"/>
                            <String fx:value="Large"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Language" minWidth="90"
                       style="-fx-text-fill:#64748b;-fx-font-size:12;"/>
                <ComboBox fx:id="cbLanguage" value="EN"
                          style="-fx-background-color:#1e2235;-fx-border-color:rgba(99,102,241,0.25);
                                 -fx-border-radius:9;-fx-background-radius:9;-fx-min-width:130;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="EN"/>
                            <String fx:value="BN"/>
                        </FXCollections>
                    </items>
                </ComboBox>
            </HBox>

            <!-- Profile Visibility -->
            <HBox fx:id="privacyBox" spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color:rgba(127,29,29,0.3);-fx-background-radius:10;
                         -fx-padding:12;-fx-border-color:rgba(127,29,29,0.5);-fx-border-radius:10;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Profile Visibility"
                           style="-fx-font-weight:bold;-fx-text-fill:#fca5a5;-fx-font-size:13;"/>
                    <Label fx:id="privacySubLabel" text="Private = no one can view your profile"
                           style="-fx-text-fill:#f87171;-fx-font-size:11;"/>
                </VBox>
                <ToggleButton fx:id="togglePrivacy" text="🌐 Public"
                              style="-fx-background-color:#22c55e;-fx-text-fill:white;
                                     -fx-font-weight:bold;-fx-background-radius:20;
                                     -fx-border-radius:20;-fx-padding:5 16;-fx-cursor:hand;"/>
            </HBox>

            <Button text="💾 Save Settings" onAction="#onSaveSettings"
                    style="-fx-background-color:linear-gradient(to right,#6366f1,#8b5cf6);
                           -fx-text-fill:white;-fx-font-weight:bold;-fx-padding:10 24;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13;"/>
        </VBox>

    </VBox>
</VBox>
</ScrollPane>
