<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  FIXES APPLIED:
  1. Added missing fx:id="detailStatus" label (was causing NullPointerException)
  2. Added missing fx:id="detailTopic" (was referenced in controller but missing)
  3. Added fx:id="searchField" TextField (was referenced in controller but missing)
  4. Added categoryFilterCombo ComboBox (was referenced in controller but missing)
  5. Fixed ALL white-background ScrollPane issues: set both -fx-background AND -fx-background-color
  6. Fixed SplitPane divider white area: added -fx-background on SplitPane itself
  7. Ensured every container explicitly overrides the default white JavaFX background
-->
<SplitPane dividerPositions="0.30"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.scholar.controller.ConsultancyController"
           style="-fx-background-color:#0d0f1a; -fx-background:#0d0f1a; -fx-padding:12;">

    <!-- ===================== LEFT PANEL: DOUBT LIST ===================== -->
    <VBox spacing="10"
          style="-fx-padding:16; -fx-background-color:#141828; -fx-background-radius:14;
                 -fx-border-color:rgba(99,102,241,0.2); -fx-border-radius:14;">

        <Button text="➕ Ask a Doubt" onAction="#onAskDoubt"
                maxWidth="Infinity"
                style="-fx-background-color:linear-gradient(to right,#7c3aed,#6366f1);
                       -fx-text-fill:white; -fx-font-weight:bold; -fx-padding:11;
                       -fx-cursor:hand; -fx-background-radius:10; -fx-font-size:13;"/>

        <!-- FIX #3 & #4: Search + Category filter were referenced in controller but not in FXML -->
        <ComboBox fx:id="categoryFilterCombo" maxWidth="Infinity"
                  style="-fx-background-color:#0d0f1a; -fx-text-fill:#e2e8f0;
                         -fx-border-color:rgba(99,102,241,0.25); -fx-border-radius:8;
                         -fx-background-radius:8; -fx-padding:4;"/>

        <TextField fx:id="searchField"
                   promptText="🔍 Search subject / topic..."
                   maxWidth="Infinity"
                   style="-fx-control-inner-background:#0d0f1a; -fx-text-fill:#e2e8f0;
                          -fx-prompt-text-fill:#64748b; -fx-background-radius:20;
                          -fx-border-color:rgba(99,102,241,0.25); -fx-border-radius:20;
                          -fx-padding:8 14;"/>

        <!-- FIX #5: ScrollPane white background — must set BOTH -fx-background and -fx-background-color
             AND style the inner VBox explicitly. The viewport background is controlled by -fx-background. -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background:#141828; -fx-background-color:transparent;
                           -fx-border-color:transparent; -fx-padding:0;">
            <VBox fx:id="doubtsListContainer" spacing="8"
                  style="-fx-background-color:#141828; -fx-padding:2 4 8 4;"/>
        </ScrollPane>
    </VBox>

    <!-- ===================== RIGHT PANEL: DETAIL + ANSWERS ===================== -->
    <BorderPane style="-fx-background-color:#0d0f1a; -fx-background:#0d0f1a;">

        <top>
            <!-- FIX #1 & #2: Added missing fx:id="detailStatus" and populated detailTopic -->
            <VBox fx:id="doubtDetailBox" spacing="8"
                  style="-fx-padding:18 20; -fx-background-color:#141828;
                         -fx-border-color:rgba(99,102,241,0.18); -fx-border-width:0 0 1 0;"
                  visible="false">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label fx:id="detailSubject"
                           style="-fx-background-color:#2563eb; -fx-text-fill:white;
                                  -fx-padding:3 10; -fx-background-radius:6; -fx-font-size:11;"/>
                    <!-- FIX #2: This was in FXML but never set in controller — now has correct fx:id -->
                    <Label fx:id="detailTopic"
                           style="-fx-background-color:#d97706; -fx-text-fill:white;
                                  -fx-padding:3 10; -fx-background-radius:6; -fx-font-size:11;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <!-- FIX #1: MISSING label — controller called detailStatus.setText() but no node existed -->
                    <Label fx:id="detailStatus"
                           style="-fx-padding:4 10; -fx-background-radius:6; -fx-font-size:11; -fx-font-weight:bold;"/>
                </HBox>
                <Label fx:id="detailTitle"
                       style="-fx-font-size:17; -fx-font-weight:bold; -fx-text-fill:#e2e8f0;"
                       wrapText="true"/>
                <Label fx:id="detailDesc"
                       style="-fx-text-fill:#94a3b8; -fx-font-size:13;" wrapText="true"/>
                <Label fx:id="detailStudent"
                       style="-fx-text-fill:#475569; -fx-font-size:11; -fx-font-style:italic;"/>
            </VBox>
        </top>

        <center>
            <!-- FIX #5 (again): center ScrollPane — white bleed from viewport fix -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background:#0d0f1a; -fx-background-color:#0d0f1a;
                               -fx-border-color:transparent; -fx-padding:0;">
                <VBox fx:id="answersContainer" spacing="14"
                      style="-fx-padding:20 28; -fx-background-color:#0d0f1a;"/>
            </ScrollPane>
        </center>

        <bottom>
            <VBox fx:id="replyBox" spacing="10"
                  style="-fx-padding:14 20; -fx-background-color:#141828;
                         -fx-border-color:rgba(99,102,241,0.18); -fx-border-width:1 0 0 0;"
                  visible="false">
                <Label text="💡 Provide a Solution (Mentors &amp; Seniors)"
                       style="-fx-font-weight:bold; -fx-text-fill:#34d399; -fx-font-size:12;"/>
                <TextArea fx:id="answerInput"
                          promptText="Write your detailed explanation here..."
                          prefRowCount="3" wrapText="true"
                          style="-fx-control-inner-background:#0d0f1a; -fx-text-fill:#e2e8f0;
                                 -fx-prompt-text-fill:#64748b; -fx-background-radius:10;
                                 -fx-border-color:rgba(16,185,129,0.3); -fx-border-radius:10;
                                 -fx-padding:10;"/>
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="submitAnswerBtn" text="Post Answer 🚀" onAction="#onSubmitAnswer"
                            style="-fx-background-color:linear-gradient(to right,#059669,#06b6d4);
                                   -fx-text-fill:white; -fx-font-weight:bold; -fx-cursor:hand;
                                   -fx-background-radius:10; -fx-padding:9 22; -fx-font-size:13;"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>
</SplitPane>
