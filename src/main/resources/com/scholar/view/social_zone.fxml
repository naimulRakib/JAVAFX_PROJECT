<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  social_zone.fxml — RESPONSIVE dark-theme rewrite
  Key fixes:
    • Left panel: prefWidth/minWidth set, no maxWidth that blocks shrinking
    • Center StackPane fills remaining space via BorderPane center slot
    • All ScrollPanes use fitToWidth="true"
    • VBox.vgrow="ALWAYS" on scroll areas so they fill height properly
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.scholar.controller.SocialZoneController"
            style="-fx-background-color:#080a14;">

    <left>
        <VBox prefWidth="250" minWidth="220"
              style="-fx-background-color:#0f1117;
                     -fx-border-color:#1a1d2e;-fx-border-width:0 1 0 0;"
              spacing="0">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:18 16 14 16;-fx-background-color:#141828;
                         -fx-border-color:#1a1d2e;-fx-border-width:0 0 1 0;">
                <Label text="⚡" style="-fx-font-size:20;"/>
                <VBox spacing="1">
                    <Label text="Scholar Zone"
                           style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                    <Label text="Social Hub" style="-fx-font-size:10;-fx-text-fill:#334155;"/>
                </VBox>
            </HBox>

            <!-- Nav items -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:transparent;-fx-background-color:transparent;
                               -fx-border-color:transparent;">
                <VBox spacing="3" style="-fx-padding:10 8;">

                    <Label text="  PUBLIC ZONE"
                           style="-fx-font-size:9;-fx-font-weight:bold;-fx-text-fill:#334155;
                                  -fx-padding:6 0 3 4;"/>

                    <Button fx:id="navGroupChat" text="🌍  Global Group Chat"
                            onAction="#showGroupChatView" maxWidth="Infinity"
                            style="-fx-background-color:rgba(37,99,235,0.2);-fx-text-fill:#60a5fa;
                                   -fx-font-weight:bold;-fx-alignment:CENTER_LEFT;-fx-padding:9 12;
                                   -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:12;"/>

                    <!-- Threads section -->
                    <VBox style="-fx-background-color:#141828;-fx-background-radius:8;
                                 -fx-border-color:#1a1d2e;-fx-border-radius:8;">
                        <Button text="🌟  Daily Threads  ▾" onAction="#showDailyThreadsView"
                                maxWidth="Infinity"
                                style="-fx-background-color:transparent;-fx-text-fill:#94a3b8;
                                       -fx-font-weight:bold;-fx-alignment:CENTER_LEFT;-fx-padding:9 12;
                                       -fx-cursor:hand;-fx-font-size:12;"/>
                        <VBox spacing="1" style="-fx-padding:0 6 6 6;">
                            <Button text="🏠  Home Feed" onAction="#showThreadsHome"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#475569;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:6 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="🌐  Public Threads" onAction="#showPublicThreads"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#475569;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:6 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Label text="  🏛️ Department"
                                   style="-fx-font-size:9;-fx-text-fill:#1e293b;-fx-padding:3 4 0 4;"/>
                            <Button text="      📚 Academics" onAction="#showThreadsAcademics"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#334155;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:5 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="      🎉 Events" onAction="#showThreadsEvents"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#334155;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:5 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="      💼 Placements" onAction="#showThreadsPlacements"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#334155;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:5 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="      🚨 Issues" onAction="#showThreadsIssues"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#334155;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:5 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Separator style="-fx-opacity:0.1;"/>
                            <Button text="👤  My Threads" onAction="#showMyThreads"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#475569;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:6 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                            <Button text="🔖  Saved Threads" onAction="#showSavedThreads"
                                    maxWidth="Infinity"
                                    style="-fx-background-color:transparent;-fx-text-fill:#475569;
                                           -fx-alignment:CENTER_LEFT;-fx-padding:6 10;
                                           -fx-background-radius:6;-fx-cursor:hand;-fx-font-size:11;"/>
                        </VBox>
                    </VBox>

                    <Label text="  PRIVATE MESSAGES"
                           style="-fx-font-size:9;-fx-font-weight:bold;-fx-text-fill:#334155;
                                  -fx-padding:10 0 3 4;"/>

                    <StackPane>
                        <Button text="📩  Message Requests" onAction="#showMessageRequestsView"
                                maxWidth="Infinity"
                                style="-fx-background-color:transparent;-fx-text-fill:#94a3b8;
                                       -fx-font-weight:bold;-fx-alignment:CENTER_LEFT;-fx-padding:9 12;
                                       -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:12;"/>
                        <Label fx:id="requestBadge" text="0" visible="false" managed="false"
                               style="-fx-background-color:#ef4444;-fx-text-fill:white;
                                      -fx-font-size:9;-fx-font-weight:bold;-fx-background-radius:10;
                                      -fx-padding:2 5;-fx-min-width:16;-fx-alignment:CENTER;"
                               StackPane.alignment="CENTER_RIGHT"/>
                    </StackPane>

                    <Button text="➕  Add Contact" onAction="#onSendNewRequest"
                            maxWidth="Infinity"
                            style="-fx-background-color:transparent;-fx-text-fill:#3b82f6;
                                   -fx-font-weight:bold;-fx-alignment:CENTER_LEFT;-fx-padding:7 12;
                                   -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:11;
                                   -fx-border-color:rgba(37,99,235,0.25);-fx-border-radius:8;"/>

                    <Label text="  CONVERSATIONS"
                           style="-fx-font-size:9;-fx-font-weight:bold;-fx-text-fill:#334155;
                                  -fx-padding:8 0 3 4;"/>
                    <VBox fx:id="contactsContainer" spacing="2"/>

                    <Label text="  NOTIFICATIONS"
                           style="-fx-font-size:9;-fx-font-weight:bold;-fx-text-fill:#334155;
                                  -fx-padding:10 0 3 4;"/>
                    <StackPane>
                        <Button text="🔔  Notifications" onAction="#showNotificationsView"
                                maxWidth="Infinity"
                                style="-fx-background-color:transparent;-fx-text-fill:#94a3b8;
                                       -fx-font-weight:bold;-fx-alignment:CENTER_LEFT;-fx-padding:9 12;
                                       -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:12;"/>
                        <Label fx:id="notificationBadge" text="" visible="false" managed="false"
                               style="-fx-background-color:#f59e0b;-fx-text-fill:white;
                                      -fx-font-size:9;-fx-font-weight:bold;-fx-background-radius:10;
                                      -fx-padding:2 6;-fx-min-width:18;-fx-alignment:CENTER;"
                               StackPane.alignment="CENTER_RIGHT"/>
                    </StackPane>

                </VBox>
            </ScrollPane>

            <!-- Bottom user info -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding:11 14;-fx-background-color:#141828;
                         -fx-border-color:#1a1d2e;-fx-border-width:1 0 0 0;">
                <Label text="👤"
                       style="-fx-background-color:#2563eb;-fx-text-fill:white;
                              -fx-background-radius:20;-fx-padding:5 8;-fx-font-size:13;"/>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="currentUserLabel" text="You"
                           style="-fx-font-weight:bold;-fx-text-fill:#e2e8f0;-fx-font-size:11;"/>
                    <Label text="● Online" style="-fx-text-fill:#22c55e;-fx-font-size:10;"/>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <center>
        <StackPane style="-fx-background-color:#080a14;">

            <!-- GROUP / PRIVATE CHAT -->
            <BorderPane fx:id="chatMainContainer" visible="true" managed="true">
                <top>
                    <VBox style="-fx-background-color:#141828;-fx-padding:13 18;
                                 -fx-border-color:#1a1d2e;-fx-border-width:0 0 1 0;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="chatHeaderLabel" text="🌍 Global Group Chat"
                                   style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"
                                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                            <Button fx:id="muteAudioBtn" text="🎤 Mute" onAction="#onToggleMute"
                                    visible="false" managed="false"
                                    style="-fx-background-color:#d97706;-fx-text-fill:white;
                                           -fx-font-weight:bold;-fx-cursor:hand;-fx-background-radius:20;
                                           -fx-padding:6 14;"/>
                            <Button text="📊 Polls" onAction="#onOpenPolls"
                                    style="-fx-background-color:#7c3aed;-fx-text-fill:white;
                                           -fx-font-weight:bold;-fx-cursor:hand;-fx-background-radius:20;
                                           -fx-padding:6 14;"/>
                            <Button fx:id="joinAudioBtn" text="🎙️ Join Voice"
                                    onAction="#onJoinAudioCall"
                                    style="-fx-background-color:#059669;-fx-text-fill:white;
                                           -fx-font-weight:bold;-fx-cursor:hand;-fx-background-radius:20;
                                           -fx-padding:6 14;"/>
                            <Button fx:id="leaveAudioBtn" text="🛑 Leave"
                                    onAction="#onLeaveAudioCall" visible="false" managed="false"
                                    style="-fx-background-color:#dc2626;-fx-text-fill:white;
                                           -fx-font-weight:bold;-fx-cursor:hand;-fx-background-radius:20;
                                           -fx-padding:6 14;"/>
                        </HBox>
                        <Label fx:id="activeVoiceUsersLabel" text="🎙️ Active in Voice: None"
                               visible="false" managed="false"
                               style="-fx-text-fill:#22c55e;-fx-font-weight:bold;-fx-font-size:11;
                                      -fx-padding:4 0 0 0;"/>
                    </VBox>
                </top>
                <center>
                    <ScrollPane fx:id="chatScroll" fitToWidth="true"
                                style="-fx-background:#080a14;-fx-background-color:#080a14;
                                       -fx-border-color:transparent;">
                        <VBox fx:id="chatContainer" spacing="5"
                              style="-fx-padding:18;"/>
                    </ScrollPane>
                </center>
                <bottom>
                    <HBox spacing="10" alignment="CENTER"
                          style="-fx-padding:11 14;-fx-background-color:#141828;
                                 -fx-border-color:#1a1d2e;-fx-border-width:1 0 0 0;">
                        <TextField fx:id="messageInput" onAction="#onSendMessage"
                                   promptText="Type a message..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-control-inner-background:#0d0f1a;-fx-text-fill:#e2e8f0;
                                          -fx-prompt-text-fill:#334155;-fx-background-radius:20;
                                          -fx-padding:10 16;-fx-border-color:#1a1d2e;
                                          -fx-border-radius:20;-fx-font-size:13;"/>
                        <Button onAction="#onSendMessage" text="Send ➤"
                                style="-fx-background-color:#2563eb;-fx-text-fill:white;
                                       -fx-background-radius:20;-fx-font-weight:bold;-fx-cursor:hand;
                                       -fx-padding:10 20;-fx-font-size:13;"/>
                    </HBox>
                </bottom>
            </BorderPane>

            <!-- DAILY THREADS FEED -->
            <BorderPane fx:id="dailyThreadsContainer" visible="false" managed="false"
                        style="-fx-background-color:#080a14;">
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding:14 18;-fx-background-color:#141828;
                                 -fx-border-color:#1a1d2e;-fx-border-width:0 0 1 0;">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label fx:id="threadsCategoryLabel" text="🌟 Daily Threads"
                                   style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                            <Label fx:id="threadsSubtitleLabel" text="Share your thoughts with the community"
                                   style="-fx-font-size:11;-fx-text-fill:#334155;"/>
                        </VBox>
                        <Button text="✏️ Create Post" onAction="#onOpenCreateThread"
                                style="-fx-background-color:#2563eb;-fx-text-fill:white;-fx-font-weight:bold;
                                       -fx-background-radius:20;-fx-padding:8 16;-fx-cursor:hand;"/>
                    </HBox>
                </top>
                <center>
                    <ScrollPane fitToWidth="true"
                                style="-fx-background:#080a14;-fx-background-color:#080a14;
                                       -fx-border-color:transparent;">
                        <VBox fx:id="threadsFeedBox" spacing="12"
                              style="-fx-padding:18 50;" alignment="TOP_CENTER">
                            <Label text="✨ Loading threads..."
                                   style="-fx-text-fill:#334155;-fx-font-size:13;"/>
                        </VBox>
                    </ScrollPane>
                </center>
            </BorderPane>

            <!-- MESSAGE REQUESTS -->
            <VBox fx:id="messageRequestsContainer" visible="false" managed="false"
                  style="-fx-background-color:#080a14;" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:16 18;-fx-background-color:#141828;
                             -fx-border-color:#1a1d2e;-fx-border-width:0 0 1 0;">
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="📩 Message Requests"
                               style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                        <Label text="Accept to start a private conversation"
                               style="-fx-font-size:11;-fx-text-fill:#334155;"/>
                    </VBox>
                </HBox>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background:#080a14;-fx-background-color:#080a14;
                                   -fx-border-color:transparent;">
                    <VBox fx:id="requestsContainer" spacing="10"
                          style="-fx-padding:18 50;" alignment="TOP_CENTER"/>
                </ScrollPane>
            </VBox>

            <!-- NOTIFICATIONS -->
            <BorderPane fx:id="notificationsContainer" visible="false" managed="false"
                        style="-fx-background-color:#080a14;">
                <top>
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-padding:14 18;-fx-background-color:#141828;
                                 -fx-border-color:#1a1d2e;-fx-border-width:0 0 1 0;">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label text="🔔 Notifications"
                                   style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e2e8f0;"/>
                            <Label text="Your recent activity and alerts"
                                   style="-fx-font-size:11;-fx-text-fill:#334155;"/>
                        </VBox>
                        <Button text="Mark All Read" onAction="#onMarkAllNotificationsRead"
                                style="-fx-background-color:transparent;-fx-text-fill:#3b82f6;
                                       -fx-font-weight:bold;-fx-cursor:hand;
                                       -fx-border-color:rgba(37,99,235,0.25);-fx-border-radius:16;
                                       -fx-padding:6 14;"/>
                    </HBox>
                </top>
                <center>
                    <ScrollPane fitToWidth="true"
                                style="-fx-background:#080a14;-fx-background-color:#080a14;
                                       -fx-border-color:transparent;">
                        <VBox fx:id="notificationsListContainer" spacing="8"
                              style="-fx-padding:18 50;" alignment="TOP_CENTER"/>
                    </ScrollPane>
                </center>
            </BorderPane>

        </StackPane>
    </center>

</BorderPane>
